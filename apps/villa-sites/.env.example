# Database (shared with landing + engine)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Email — inquiry notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nestino <notifications@nestino.com>

# Rate limiting (Upstash Redis — same instance as landing is fine)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Internal
NEXT_PUBLIC_VILLA_BASE_DOMAIN=nestino.com