# Database (shared with landing + engine).
# Production: set on Vercel so Host→tenant resolves via sites.custom_domain (www.villasilyan.com).
DATABASE_URL=postgresql://user:pass@host:5432/db

# Email — inquiry notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nestino <notifications@nestino.com>

# Optional (e.g. rate limiting). CMS publish uses Nestino API + ISR only — no Redis required for content.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Internal
NEXT_PUBLIC_VILLA_BASE_DOMAIN=nestino.com

# Cloudinary (image migration + uploads)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<cloud_name>

# Nestino publish + CMS fetch (add all four on Vercel Production + Preview if needed)
NESTINO_API_BASE_URL=https://nestino-backend-production.up.railway.app
NESTINO_PUBLISH_SECRET=vsylan_test_secret_2026
NESTINO_SITE_ID=cmoxcw9bp0000ivg2xrqmznvl